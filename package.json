{
  "name": "prayogam-foundation-mern",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "predev": "node scripts/free-dev-ports.js",
    "preserver": "node scripts/free-dev-ports.js",
    "install-all": "npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"node server/server.js\" \"npm --prefix client run dev\"",
    "server": "node server/server.js",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
